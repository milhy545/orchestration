          "secret": true,
          "placeholder": "AIza...",
          "default": "",
          "validation": { "validator": "gemini" }
        },
        {
          "name": "NOTION_API_KEY",
          "label": "Notion API Key",
          "target_env": "NOTION_API_KEY",
          "input_type": "password",
          "secret": true,
          "placeholder": "secret_...",
          "default": "NOTION_PLACEHOLDER",
          "validation": { "validator": "notion" }
        }
      ]
