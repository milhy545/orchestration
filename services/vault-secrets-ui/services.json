      "env_file": "/vault/runtime/security-mcp.env",
      "restart_target": "security-mcp",
      "delivery_mode": "file",
      "description": "Shared internal JWT secret mapped as JWT_SECRET_KEY.",
      "fields": [
        {
          "name": "JWT_SECRET",
          "label": "JWT Secret",
          "target_env": "JWT_SECRET_KEY",
          "input_type": "password",
          "secret": true,
          "placeholder": "super-secret",
          "default": ""
        }
      ]
    },
    {
      "id": "marketplace-mcp",
      "label": "MARKETPLACE MCP",
      "vault_path": "orchestration/internal-auth",
      "env_file": "/vault/runtime/marketplace-mcp.env",
      "restart_target": "marketplace-mcp",
      "delivery_mode": "file",
      "description": "Shared internal JWT secret mapped as JWT_SECRET.",
      "fields": [
        {
          "name": "JWT_SECRET",
          "label": "JWT Secret",
          "target_env": "JWT_SECRET",
          "input_type": "password",
          "secret": true,
          "placeholder": "super-secret",
          "default": ""
        }
      ]
    },
    {
      "id": "common-mcp",
      "label": "COMMON MCP",
      "vault_path": "orchestration/common-mcp",
      "env_file": "/vault/runtime/common-mcp.env",
      "restart_target": "vault-agent-common",
      "delivery_mode": "file",
      "description": "Shared namespace for orchestration-wide secrets, including Notion for Gemini CLI.",
      "fields": [
        {
          "name": "OPENAI_API_KEY",
          "label": "OpenAI API Key",
          "target_env": "OPENAI_API_KEY",
          "input_type": "password",
          "secret": true,
          "placeholder": "sk-...",
          "default": "",
          "validation": { "validator": "openai", "base_url": "https://api.openai.com/v1" }
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "label": "Anthropic API Key",
          "target_env": "ANTHROPIC_API_KEY",
          "input_type": "password",
          "secret": true,
          "placeholder": "anth-...",
          "default": "",
          "validation": { "validator": "anthropic" }
        },
        {
          "name": "GEMINI_API_KEY",
          "label": "Gemini API Key",
          "target_env": "GEMINI_API_KEY",
