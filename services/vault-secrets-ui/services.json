          "name": "SMTP_SERVER",
          "label": "SMTP Server",
          "target_env": "SMTP_SERVER",
          "input_type": "text",
          "secret": false,
          "placeholder": "smtp.gmail.com",
          "default": "smtp.gmail.com"
        },
