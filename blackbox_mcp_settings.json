{
  "mcpServers": {
    "mega-orchestrator": {
      "httpUrl": "http://192.168.0.58:7000/mcp",
      "timeout": 30000,
      "trust": true,
      "description": "Mega-Orchestrator remote MCP endpoint"
    },
    "github.com/elevenlabs/elevenlabs-mcp": {
      "command": "python",
      "args": ["-m", "elevenlabs_mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "your-elevenlabs-api-key",
        "ELEVENLABS_MCP_OUTPUT_MODE": "files",
        "ELEVENLABS_MCP_BASE_PATH": "/home/orchestration/mcp-servers/elevenlabs-mcp/outputs"
      },
      "description": "ElevenLabs MCP server pro text-to-speech, klonování hlasů a zpracování audia",
      "capabilities": [
        "text-to-speech",
        "voice-cloning",
        "audio-transcription",
        "voice-design",
        "sound-effects"
      ]
    }
  }
}
